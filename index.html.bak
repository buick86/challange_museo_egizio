    <script>
        // --- CREA LA MAGIA ---
        // before-img = frammento (sempre visibile di default)
        // after-img  = restaurato (nascosto, rivelato dal pulsante)
        function createMagic() {
            const btn = document.getElementById('magic-btn');
            const btnText = document.getElementById('magic-btn-text');
            const afterImg = document.getElementById('after-img');
            const beforeImg = document.getElementById('before-img');
            const sliderEl = document.getElementById('slider');

            const isRestored = btn.dataset.state === 'restored';
            btn.disabled = true;
            btn.classList.add('animating');
            sliderEl.disabled = true;

            const duration = 3000;
            const start = performance.now();

            if (!isRestored) {
                // Frammento → Restaurato: afterImg (restaurato) fa fade da invisibile a visibile sopra tutto
                btnText.textContent = 'LA MAGIA È IN CORSO...';
                afterImg.style.clipPath = 'none';
                afterImg.style.zIndex = '2';
                afterImg.style.opacity = '0';
                beforeImg.style.zIndex = '1';

                function fadeIn(now) {
                    const progress = Math.min((now - start) / duration, 1);
                    const eased = progress < 0.5
                        ? 2 * progress * progress
                        : 1 - Math.pow(-2 * progress + 2, 2) / 2;
                    afterImg.style.opacity = eased;
                    if (progress < 1) {
                        requestAnimationFrame(fadeIn);
                    } else {
                        afterImg.style.opacity = '1';
                        // Vibrazione aptica (Android)
                        if (navigator.vibrate) navigator.vibrate([40, 30, 80]);
                        // Pulse visivo sul contenitore
                        document.querySelector('.comparison-container').classList.add('magic-complete');
                        setTimeout(() => document.querySelector('.comparison-container').classList.remove('magic-complete'), 1200);
                        sliderEl.value = 0;
                        swipeLine.style.left = '0%';
                        sliderEl.disabled = false;
                        btn.classList.remove('animating');
                        btn.disabled = false;
                        btn.dataset.state = 'restored';
                        btnText.textContent = "RITORNA ALL'ORIGINALE";
                    }
                }
                requestAnimationFrame(fadeIn);

            } else {
                // Restaurato → Frammento: beforeImg (frammento) appare sopra tutto in fade
                btnText.textContent = 'RITORNO IN CORSO...';
                beforeImg.style.zIndex = '3';
                beforeImg.style.opacity = '0';
                swipeLine.style.left = '100%';

                function fadeInBefore(now) {
                    const progress = Math.min((now - start) / duration, 1);
                    const eased = progress < 0.5
                        ? 2 * progress * progress
                        : 1 - Math.pow(-2 * progress + 2, 2) / 2;
                    beforeImg.style.opacity = eased;
                    if (progress < 1) {
                        requestAnimationFrame(fadeInBefore);
                    } else {
                        // Ripristina tutto allo stato iniziale
                        beforeImg.style.opacity = '1';
                        beforeImg.style.zIndex = '1';
                        afterImg.style.opacity = '1';
                        afterImg.style.clipPath = 'inset(0 0 0 100%)';
                        afterImg.style.zIndex = '2';
                        sliderEl.value = 100;
                        sliderEl.disabled = false;
                        btn.classList.remove('animating');
                        btn.disabled = false;
                        btn.dataset.state = 'original';
                        btnText.textContent = 'CREA LA MAGIA';
                    }
                }
                requestAnimationFrame(fadeInBefore);
            }
        }

        const slider = document.getElementById('slider');
        const afterImg = document.getElementById('after-img');
        const swipeLine = document.getElementById('swipe-line');

        // --- ZOOM doppio tap/click ---
        (function() {
            const container = document.querySelector('.comparison-container');
            let lastTap = 0;
            let zoomed = false;
            let tapTimer = null;

            function toggleZoom(clientX, clientY) {
                zoomed = !zoomed;
                const rect = container.getBoundingClientRect();
                if (zoomed) {
                    const px = ((clientX - rect.left) / rect.width * 100).toFixed(1) + '%';
                    const py = ((clientY - rect.top) / rect.height * 100).toFixed(1) + '%';
                    container.style.setProperty('--zoom-x', px);
                    container.style.setProperty('--zoom-y', py);
                }
                container.classList.toggle('zoomed', zoomed);
                document.getElementById('slider').style.pointerEvents = zoomed ? 'none' : 'auto';
            }

            // Touch: doppio tap con touchstart (più reattivo di touchend)
            container.addEventListener('touchstart', (e) => {
                const now = Date.now();
                const gap = now - lastTap;
                if (gap < 350 && gap > 30) {
                    e.preventDefault();
                    if (tapTimer) { clearTimeout(tapTimer); tapTimer = null; }
                    const t = e.touches[0];
                    toggleZoom(t.clientX, t.clientY);
                } else {
                    tapTimer = setTimeout(() => { tapTimer = null; }, 350);
                }
                lastTap = now;
            }, { passive: false });

            // Mouse: doppio click desktop
            container.addEventListener('dblclick', (e) => {
                toggleZoom(e.clientX, e.clientY);
            });
        })();

        // --- SCROLL FADE-IN ---
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
        }, { threshold: 0.1 });
        document.querySelectorAll('.fade-in-section').forEach(el => observer.observe(el));
        window.addEventListener('load', () => {
            setTimeout(() => {
                slider.classList.add('hint-active');
                setTimeout(() => slider.classList.remove('hint-active'), 2000);
            }, 800);
            // Rimuovi label dopo animazione
            setTimeout(() => {
                const hint = document.getElementById('swipe-hint');
                if (hint) hint.remove();
            }, 7000);
        });

        // Nasconde hint al primo tocco/drag
        slider.addEventListener('pointerdown', () => {
            const hint = document.getElementById('swipe-hint');
            if (hint) hint.remove();
        }, { once: true });

        slider.oninput = (e) => {
            const afterImg = document.getElementById('after-img');
            afterImg.style.opacity = '1';
            afterImg.style.clipPath = `inset(0 0 0 ${e.target.value}%)`;
            swipeLine.style.left = `${e.target.value}%`;
        };

        const data = {
            it: {
                title: "Papiro con due capitoli del Libro dei Morti",
                confText: "Affidabilità del Restauro: 85%",
                audioText: "Ascolta la spiegazione",
                meta: {
                    prov: "Provenienza:", provV: "Tebe (?)",
                    acq: "Acquisizione:", acqV: "Bernardino Drovetti - 1824",
                    dyn: "Dinastia:", dynV: "19ª (1292-1191 a.C.)",
                    base: "Datazione su base:", baseV: "Paleografia; paralleli testuali; scrittura retrograda",
                    size: "Misure:", loc: "Posizione attuale:", locV: "Galleria della Scrittura - sezione 9/4"
                },
                descMain: "Il reperto Cat. 1827/5 è composto da una serie di frammenti appartenenti a un unico papiro risalente al Nuovo Regno. Il recto mostra una vignetta policroma che ritrae un uccello con testa e piedi umani; questa è la rappresentazione di una delle parti dello spirito del defunto, quella chiamata Ba, parola spesso tradotta come 'anima'.",
                descDetails: "Il testo scritto in geroglifici corsivi contiene due capitoli incompleti del Libro dei Morti. Nello specifico, i frammenti contengono le formule 84 e 85, appartenenti al gruppo delle formule di trasformazione. Queste formule permettevano al defunto di assumere diverse forme, in questi capitoli la forma di un airone e quella di un Ba vivente, permettendo al defunto di acquisire i loro comportamenti e caratteristiche simboliche per affrontare il viaggio nell'aldilà. Insolita, dato il contenuto del recto, è la presenza sul retro di una singola linea di geroglifici, anch'essa incompleta e di dubbia interpretazione, probabilmente parte di una formula di offerta.",
                faqTitle: "Chiedi all'AI",
                versoTitle: "Il Retro del Papiro",
                versoText: "Sul retro del papiro è presente una sola riga di geroglifici, incompleta e di interpretazione incerta. Considerati i pochi paralleli esistenti, potrebbe far parte di una formula Htp-di-nswt — la classica formula di offerta funeraria con cui si invocava il re e gli dei per garantire al defunto pane, birra, buoi e oche nell'aldilà. La sua presenza sul retro di un papiro già scritto è insolita e suggerisce un possibile riutilizzo del supporto da parte dello scriba.",
                glyphTitle: "Schema dei caratteri geroglifici ricostruiti",
                glyphCaption: "Ricostruzione delle colonne di geroglifici — le aree tratteggiate indicano le lacune integrate",
                questions: [
                    "Perché il papiro è in frammenti?", 
                    "Cosa succede trasformandosi in airone?", 
                    "Il retro del papiro?", 
                    "Geroglifici corsivi?",
                    "Chi era il proprietario?", 
                    "Cos'è il Libro dei Morti?", 
                    "Perché la 19ª Dinastia è importante?", 
                    "Cosa significa 'scrittura retrograda'?"
                ],
                answers: [
                    "Questi frammenti (Cat. 1827) appartenevano a un insieme di cinquanta e più pezzi incollati nell'Ottocento su carta sugante, senza un ordine preciso. Nel tempo, l'umidità e la manipolazione hanno accelerato il degrado. Il restauro virtuale che vedi cerca di ridare senso a questo puzzle millenario, ricomponendo le formule e le vignette originali.",
                    "La formula 84 permetteva al defunto di diventare un airone Benu, uccello sacro legato al sole nascente. Trasformandosi, il defunto acquisiva il potere di 'volare via' dal mondo dei morti per tornare a vedere la luce ogni mattina, proprio come il sole che risorge ogni alba.",
                    "Il retro del papiro presenta una singola riga di geroglifici incompleta e di dubbia interpretazione, insolita per un testo funerario di questo tipo. Gli studiosi ipotizzano che si tratti di parte di una formula di offerta, o che il foglio sia stato riutilizzato da uno scriba per un appunto secondario.",
                    "I geroglifici corsivi, detti anche 'ieratici funerari', erano una forma di scrittura semplificata usata per i testi sacri. Più rapida da tracciare rispetto ai geroglifici monumentali incisi nella pietra, permetteva agli scribi di copiare lunghi testi come il Libro dei Morti su papiro con maggiore velocità.",
                    "Nei frammenti compaiono i nomi di Har-em-ua e Baka, entrambi seguiti dal titolo 'giustificato', segno che erano già defunti al momento della scrittura. Possedere un papiro così finemente illustrato indica che erano persone di alto rango nella società della XIX Dinastia, probabilmente funzionari o sacerdoti.",
                    "Non era un vero 'libro', ma una raccolta di formule magiche scritte su papiro e poste nelle tombe. Servivano come una sorta di 'manuale di istruzioni' per superare mostri e prove nel tribunale di Osiride, dio dei morti, e ottenere la vita eterna nell'aldilà.",
                    "La XIX Dinastia è l'epoca di Ramesse II, il faraone più celebre dell'antico Egitto. Fu un periodo di grande splendore artistico e religioso: la produzione di papiri funerari raggiunse il suo apice, con illustrazioni sempre più elaborate e testi accuratamente copiati dagli scribi del tempio.",
                    "Nella scrittura retrograda i segni geroglifici sono rivolti verso l'inizio della riga anziché verso la fine, come avviene di norma. Questo accorgimento, tipico di alcuni testi magici e funerari, aveva probabilmente una funzione protettiva: si credeva che invertire i segni neutralizzasse il potere dei geroglifici raffiguranti esseri viventi."
                ]
            },
            en: {
                title: "Papyrus with two chapters from the Book of the Dead",
                confText: "Restoration Reliability: 85%",
                audioText: "Listen to explanation",
                meta: {
                    prov: "Provenance:", provV: "Thebes (?)",
                    acq: "Acquisition:", acqV: "Bernardino Drovetti - 1824",
                    dyn: "Dynasty:", dynV: "19 (1292-1191 BC)",
                    base: "Bases for date:", baseV: "Paleography; textual Parallels; Retrograde writing",
                    size: "Measurements:", loc: "Current location:", locV: "Galleria della Scrittura - section 9/4"
                },
                descMain: "Cat. 1827/5 consists of a series of fragments belonging to a single papyrus dating to the New Kingdom. The recto shows a polychrome vignette depicting a bird with human head and feet; this is the representation of one of the parts of the spirit of the deceased, the one called ba, a word often translated as 'soul'.",
                descDetails: "The text written in cursive hieroglyphs contains two incomplete chapters of the Book of the Dead. Specifically, the fragments contain the spells 84 and 85, belonging to the group of transformation spells. Those spells would allow the deceased to take different formes, in this chapters the shape of a heron and the one of a living Ba, allowing the deceased to acquire their behaviors and symbolic characteristics to face the journey through the afterlife. Unusual, given the content of the recto, is the presence on the back of a single line of hieroglyphs, also incomplete and of dubious interpretation, probably being part of an offering formula.",
                faqTitle: "Ask the AI",
                versoTitle: "The Verso of the Papyrus",
                versoText: "On the verso there is only one line of hieroglyphics, incomplete and of uncertain interpretation. Considering the few existing parallels, it could be part of a Htp-di-nswt formula — the classic funerary offering formula invoking the king and gods to provide the deceased with bread, beer, oxen and geese in the afterlife. Its presence on the back of an already-written papyrus is unusual and suggests a possible reuse of the support by the scribe.",
                glyphTitle: "Reconstructed hieroglyphic character schema",
                glyphCaption: "Reconstruction of hieroglyphic columns — hatched areas indicate integrated lacunae",
                questions: [
                    "Why is the papyrus fragmented?", 
                    "What happens when transformed into a heron?", 
                    "The back of the papyrus?", 
                    "Cursive hieroglyphs?",
                    "Who owned this papyrus?", 
                    "What is the Book of the Dead?", 
                    "Why is the 19th Dynasty important?", 
                    "What is retrograde writing?"
                ],
                answers: [
                    "These fragments (Cat. 1827) were part of a group of fifty or more pieces glued onto blotting paper in the 19th century without any particular order. Over time, humidity and handling accelerated their deterioration. The virtual restoration you see attempts to reassemble this ancient puzzle by reconstructing the original spells and vignettes.",
                    "Spell 84 allowed the deceased to become a Benu heron, the sacred bird associated with the rising sun. By transforming, the deceased gained the power to 'fly away' from the realm of the dead and witness the light each morning, just as the sun is reborn at every dawn.",
                    "The back of the papyrus contains a single incomplete line of hieroglyphs of uncertain interpretation, unusual for a funerary text of this kind. Scholars suggest it may be part of an offering formula, or that the sheet was reused by a scribe for a secondary note.",
                    "Cursive hieroglyphs, also known as 'funerary hieratic', were a simplified form of writing used for sacred texts. Faster to trace than monumental hieroglyphs carved in stone, they allowed scribes to copy long texts like the Book of the Dead onto papyrus more quickly.",
                    "The fragments bear the names Har-em-ua and Baka, both followed by the title 'justified', indicating they were already deceased at the time of writing. Owning such a finely illustrated papyrus suggests they were high-ranking individuals in 19th Dynasty society, likely officials or priests.",
                    "It was not a true 'book', but a collection of magical spells written on papyrus and placed in tombs. They served as a kind of instruction manual for overcoming monsters and trials in the court of Osiris, god of the dead, in order to attain eternal life.",
                    "The 19th Dynasty is the era of Ramesses II, ancient Egypt's most celebrated pharaoh. It was a period of great artistic and religious splendour: the production of funerary papyri reached its peak, with increasingly elaborate illustrations and texts carefully copied by temple scribes.",
                    "In retrograde writing, hieroglyphic signs face the beginning of the line rather than the end, as is normally the case. This practice, typical of certain magical and funerary texts, likely had a protective function: inverting the signs was believed to neutralise the power of glyphs depicting living creatures."
                ]
            }
        };

        let currentLang = 'it';

        function changeLang(lang) {
            currentLang = lang;
            document.getElementById('title').innerText = data[lang].title;
            document.getElementById('conf-text').innerText = data[lang].confText;
            document.getElementById('desc-main').innerText = data[lang].descMain;
            document.getElementById('desc-details').innerText = data[lang].descDetails;
            document.getElementById('audio-text').innerText = data[lang].audioText;
            document.getElementById('faq-section-title').innerText = data[lang].faqTitle;
            document.getElementById('verso-text').innerText = data[lang].versoText;
            document.getElementById('retro-block-title').innerText = data[lang].versoTitle;
            document.getElementById('thumb-label-retro').innerText = data[lang].versoTitle;
            document.getElementById('thumb-label-glyph').innerText = data[lang].glyphTitle;
            // Aggiorna lightbox se aperto
            if (currentCaptionKey) {
                document.getElementById('lightbox-caption').textContent = lightboxCaptions[currentCaptionKey]?.[lang] || '';
            }

            document.getElementById('meta-prov-lab').innerText = data[lang].meta.prov;
            document.getElementById('meta-prov-val').innerText = data[lang].meta.provV;
            document.getElementById('meta-acq-lab').innerText = data[lang].meta.acq;
            document.getElementById('meta-acq-val').innerText = data[lang].meta.acqV;
            document.getElementById('meta-dyn-lab').innerText = data[lang].meta.dyn;
            document.getElementById('meta-dyn-val').innerText = data[lang].meta.dynV;
            document.getElementById('meta-base-lab').innerText = data[lang].meta.base;
            document.getElementById('meta-base-val').innerText = data[lang].meta.baseV;
            document.getElementById('meta-size-lab').innerText = data[lang].meta.size;
            document.getElementById('meta-loc-lab').innerText = data[lang].meta.loc;
            document.getElementById('meta-loc-val').innerText = data[lang].meta.locV;
            
            document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-${lang}`).classList.add('active');

            const container = document.getElementById('faq-container');
            container.innerHTML = '';
            data[lang].questions.forEach((q, i) => {
                const btn = document.createElement('button');
                btn.className = 'faq-btn';
                btn.innerText = q;
                btn.onclick = () => showAnswer(i);
                container.appendChild(btn);
            });
            document.getElementById('ai-response').style.display = 'none';
        }

        function showAnswer(index) {
            const res = document.getElementById('ai-response');
            res.style.display = 'block';
            res.innerText = data[currentLang].answers[index];
            res.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // --- LIGHTBOX ---
        const lightboxCaptions = {
            'retro-caption': {
                it: 'Il retro del papiro Cat. 1827/5 — riga di geroglifici della formula Htp-di-nswt',
                en: 'The verso of papyrus Cat. 1827/5 — hieroglyphic line of the Htp-di-nswt formula'
            },
            'glyph-caption': {
                it: 'Schema dei caratteri geroglifici ricostruiti — le aree tratteggiate indicano le lacune integrate',
                en: 'Reconstructed hieroglyphic character schema — hatched areas indicate integrated lacunae'
            }
        };
        let currentCaptionKey = '';

        function openLightbox(src, captionKey) {
            currentCaptionKey = captionKey;
            document.getElementById('lightbox-img').src = src;
            document.getElementById('lightbox-caption').textContent = lightboxCaptions[captionKey][currentLang];
            document.getElementById('lightbox-overlay').classList.add('active');
        }

        function closeLightbox(e) {
            if (!e || e.target === document.getElementById('lightbox-overlay') || e.currentTarget.classList.contains('lightbox-close')) {
                document.getElementById('lightbox-overlay').classList.remove('active');
            }
        }
        const shareTextIT = 'Scopri il papiro del Libro dei Morti al Museo Egizio di Torino — una finestra sull\'antico Egitto, restaurata digitalmente. 🪶 #ME-Scripta #MuseoEgizio #LibroDeiMorti #EgittoAntico';
        const shareTextEN = 'Discover the Book of the Dead papyrus at the Museo Egizio in Turin — a window into ancient Egypt, digitally restored. 🪶 #ME-Scripta #MuseoEgizio #BookOfTheDead #AncientEgypt';

        function shareToInstagram(e) {
            e.preventDefault();
            triggerShare('instagram');
        }

        function shareToTiktok(e) {
            e.preventDefault();
            triggerShare('tiktok');
        }

        function triggerShare(platform) {
            const text = currentLang === 'it' ? shareTextIT : shareTextEN;
            // Aggiorna testo nel popup
            document.getElementById('share-text-box').textContent = text;

            // Prova Web Share API (mobile nativo)
            if (navigator.share) {
                navigator.share({
                    title: 'Cat. 1827/5 - Museo Egizio',
                    text: text,
                    url: window.location.href
                }).catch(() => {
                    // Utente ha annullato o non supportato: mostra popup
                    showSharePopup(platform);
                });
            } else {
                showSharePopup(platform);
            }
        }

        function showSharePopup(platform) {
            document.getElementById('share-overlay').classList.add('active');
            document.getElementById('share-overlay').dataset.platform = platform || '';
            // Reset bottone copia
            const btn = document.getElementById('share-copy-btn');
            btn.textContent = '📋 Copia testo e hashtag';
            btn.classList.remove('copied');
        }

        function closeSharePopup(e) {
            if (!e || e.target === document.getElementById('share-overlay') || e.currentTarget === document.querySelector('.share-close')) {
                document.getElementById('share-overlay').classList.remove('active');
            }
        }

        function copyShareText() {
            const text = document.getElementById('share-text-box').textContent;
            navigator.clipboard.writeText(text).then(() => {
                const btn = document.getElementById('share-copy-btn');
                btn.textContent = '✓ Copiato!';
                btn.classList.add('copied');
            });
        }

        function openAfterCopy(platform) {
            copyShareText();
            setTimeout(() => {
                if (platform === 'instagram') {
                    window.location.href = 'instagram://camera';
                    setTimeout(() => window.open('https://www.instagram.com/create/story/', '_blank'), 1500);
                } else {
                    window.location.href = 'snssdk1233://';
                    setTimeout(() => window.open('https://www.tiktok.com/upload', '_blank'), 1500);
                }
            }, 600);
        }

        function sharePage() {
            triggerShare('');
        }

        function speakText() {
            window.speechSynthesis.cancel();
            const btn = document.getElementById('audio-btn');
            if (btn.classList.contains('speaking')) {
                btn.classList.remove('speaking');
                return;
            }
            const textToRead = data[currentLang].descMain + " " + data[currentLang].descDetails;
            const utterance = new SpeechSynthesisUtterance(textToRead);
            utterance.lang = currentLang === 'it' ? 'it-IT' : 'en-US';
            utterance.onend = () => btn.classList.remove('speaking');
            btn.classList.add('speaking');
            window.speechSynthesis.speak(utterance);
        }

        changeLang('it');
    </script>
</body>
</html>