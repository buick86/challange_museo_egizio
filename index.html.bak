<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cat. 1827/5 - Museo Egizio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        :root { --gold: #c5a059; --bright-gold: #FFD700; --dark: #121212; --card: #1e1e1e; }

        * { box-sizing: border-box; }

        body { font-family: 'EB Garamond', serif; background: var(--dark); color: #e0e0e0; margin: 0; padding: 12px 15px; display: flex; flex-direction: column; align-items: center; }

        /* TOP BAR */
        .top-bar { width: 100%; max-width: 600px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .lang-switch { display: flex; gap: 8px; }
        button.lang-btn { background: transparent; border: 1px solid var(--gold); color: var(--gold); padding: 5px 8px; cursor: pointer; border-radius: 4px; transition: 0.3s; font-family: sans-serif; display: flex; align-items: center; justify-content: center; }
        button.lang-btn.active { background: var(--gold); color: black; }
        .social-actions { display: flex; gap: 8px; align-items: center; }
        .share-btn, .insta-btn { background: var(--gold); border: none; width: 34px; height: 34px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s; }
        .share-btn:hover, .insta-btn:hover { transform: scale(1.1); box-shadow: 0 0 10px rgba(197,160,89,0.5); }

        /* COMPARISON */
        .comparison-container { position: relative; width: 100%; max-width: 600px; height: min(90vw, 580px); overflow: hidden; border: 2px solid var(--gold); border-radius: 8px; background: #000; }
        .papiro-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; }
        #after-img { clip-path: inset(0 0 0 100%); }

        .swipe-line { position: absolute; top: 0; bottom: 0; left: 100%; width: 2px; background: var(--bright-gold); z-index: 9; pointer-events: none; box-shadow: 0 0 8px rgba(255,215,0,0.5); }

        #slider { position: absolute; top: 0; left: 0; width: 100%; height: 100%; appearance: none; background: transparent; cursor: pointer; z-index: 10; margin: 0; }
        #slider::-webkit-slider-thumb { appearance: none; width: 34px; height: 34px; background: var(--bright-gold); border: 3px solid white; border-radius: 50%; cursor: ew-resize; box-shadow: 0 0 15px rgba(0,0,0,0.8); }
        #slider::-moz-range-thumb { width: 34px; height: 34px; background: var(--bright-gold); border: 3px solid white; border-radius: 50%; cursor: ew-resize; }

        /* HINT swipe */
        @keyframes hintPulse {
            0%   { transform: translateX(0) scale(1);   opacity: 1; }
            20%  { transform: translateX(-18px) scale(1.15); opacity: 1; }
            40%  { transform: translateX(10px) scale(1.05); opacity: 1; }
            60%  { transform: translateX(-8px) scale(1.1);  opacity: 1; }
            80%  { transform: translateX(4px) scale(1.02);  opacity: 1; }
            100% { transform: translateX(0) scale(1);   opacity: 1; }
        }
        @keyframes hintLabelFade {
            0%   { opacity: 0; transform: translateY(4px); }
            15%  { opacity: 1; transform: translateY(0); }
            75%  { opacity: 1; }
            100% { opacity: 0; }
        }
        .swipe-hint-label {
            position: absolute;
            bottom: 10px; left: 50%; transform: translateX(-50%);
            background: rgba(0,0,0,0.65);
            color: var(--bright-gold);
            font-family: 'Cinzel', serif;
            font-size: 0.7em;
            letter-spacing: 2px;
            padding: 5px 14px;
            border-radius: 20px;
            border: 1px solid rgba(255,215,0,0.3);
            pointer-events: none;
            z-index: 11;
            white-space: nowrap;
            animation: hintLabelFade 7s ease forwards;
        }
        #slider.hint-active::-webkit-slider-thumb { animation: hintPulse 1.2s ease 0.3s 1; }
        #slider.hint-active::-moz-range-thumb     { animation: hintPulse 1.2s ease 0.3s 1; }

        /* CONFIDENCE */
        .confidence-container { width: 100%; max-width: 600px; margin-top: 16px; text-align: left; }
        .confidence-label { font-family: sans-serif; font-size: 0.72em; color: #aaa; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; display: block; }
        .confidence-bar-bg { width: 100%; height: 6px; background: #333; border-radius: 3px; overflow: hidden; }
        .confidence-bar-fill { width: 85%; height: 100%; background: linear-gradient(to right, #ff4e50, #f9d423, #00ff00); border-radius: 3px; }

        /* META */
        .meta-section { width: 100%; max-width: 600px; margin-top: 18px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; font-family: sans-serif; font-size: 0.78em; color: #888; line-height: 1.4; border-top: 1px solid #333; padding-top: 14px; }
        .meta-item b { color: var(--gold); text-transform: uppercase; font-size: 0.9em; }
        .current-loc { grid-column: span 2; margin-top: 4px; color: #aaa; font-style: italic; }

        /* CONTENT */
        .content { max-width: 600px; width: 100%; margin-top: 20px; }
        .catalog-num { color: var(--gold); font-size: 0.75em; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 6px; font-family: 'Cinzel', serif; }
        h2 { font-family: 'Cinzel', serif; font-weight: 600; margin-top: 0; color: #fff; font-size: clamp(1.2em, 3.8vw, 1.55em); border-bottom: 1px solid #333; padding-bottom: 10px; line-height: 1.3; }
        p { line-height: 1.85; text-align: justify; font-size: clamp(1.05em, 3vw, 1.18em); color: #ccc; }

        /* AUDIO */
        .audio-btn { background: #2a2a2a; color: white; border: 1px solid #444; width: 100%; padding: 12px; margin: 14px 0; border-radius: 50px; display: flex; align-items: center; justify-content: center; gap: 10px; cursor: pointer; font-family: sans-serif; transition: border-color 0.2s; }
        .audio-btn:hover { border-color: var(--gold); }
        .audio-btn.speaking { border-color: var(--bright-gold); box-shadow: 0 0 10px rgba(255,215,0,0.2); }
        .audio-btn.speaking .audio-icon { animation: audioPulse 0.8s ease-in-out infinite; }
        @keyframes audioPulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.3); } }

        /* FAQ */
        .faq-section { width: 100%; max-width: 600px; margin-top: 28px; }
        .faq-title { font-family: 'Cinzel', serif; border-bottom: 1px solid var(--gold); padding-bottom: 8px; margin-bottom: 14px; font-size: 1.1em; color: var(--gold); text-transform: uppercase; letter-spacing: 1px; }
        #faq-container { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .faq-btn { display: block; width: 100%; text-align: left; background: var(--card); color: #ddd; padding: 13px; margin-bottom: 0; border: 1px solid transparent; border-radius: 8px; font-size: 0.95em; cursor: pointer; transition: border-color 0.2s, color 0.2s; font-family: 'EB Garamond', serif; font-style: italic; line-height: 1.4; }
        .faq-btn:hover { border-color: var(--gold); color: #fff; }
        #ai-response { background: #1c1a14; padding: 16px 18px; border-radius: 8px; display: none; border-left: 4px solid var(--gold); margin-bottom: 16px; line-height: 1.7; color: #eee; font-size: 1.05em; }

        /* EXTERNAL LINKS */
        .external-links { width: 100%; max-width: 600px; display: flex; gap: 8px; margin: 24px 0 16px 0; }
        .link-btn { flex: 1; padding: 10px 5px; text-align: center; border-radius: 8px; text-decoration: none; font-family: sans-serif; font-weight: bold; font-size: clamp(0.55em, 1.5vw, 0.65em); transition: 0.3s; letter-spacing: 0.5px; display: flex; align-items: center; justify-content: center; gap: 5px; }
        .link-btn svg { width: 18px; height: 18px; flex-shrink: 0; }
        .btn-museo { border: 1px solid var(--gold); color: var(--gold); }
        .btn-yt { border: 1px solid #FF0000; color: #FF0000; }
        .btn-vt { border: 1px solid #00d4ff; color: #00d4ff; }
        .btn-museo:hover { background: var(--gold); color: black; }
        .btn-yt:hover { background: #FF0000; color: white; }
        .btn-vt:hover { background: #00d4ff; color: black; }
        .btn-museo svg { fill: var(--gold); }
        .btn-museo:hover svg { fill: black; }
        .btn-vt svg { stroke: #00d4ff; }
        .btn-vt:hover svg { stroke: black; }

        /* SHARE POPUP */
        .share-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.75); z-index: 1000;
            align-items: center; justify-content: center; padding: 20px;
        }
        .share-overlay.active { display: flex; }
        .share-modal {
            background: #1a1500; border: 1.5px solid var(--gold);
            border-radius: 12px; padding: 24px; width: 100%; max-width: 360px;
            position: relative;
        }
        .share-modal h3 {
            font-family: 'Cinzel', serif; color: var(--gold);
            font-size: 1em; letter-spacing: 2px; margin: 0 0 6px 0;
            text-transform: uppercase;
        }
        .share-modal p { font-size: 0.85em; color: #aaa; margin: 0 0 16px 0; line-height: 1.5; }
        .share-text-box {
            background: #111; border: 1px solid #444; border-radius: 8px;
            padding: 12px; font-family: 'EB Garamond', serif; font-size: 0.95em;
            color: #eee; line-height: 1.6; margin-bottom: 12px; user-select: all;
        }
        .share-copy-btn {
            width: 100%; padding: 11px; background: var(--gold); color: #000;
            border: none; border-radius: 8px; font-family: 'Cinzel', serif;
            font-size: 0.85em; letter-spacing: 1px; cursor: pointer;
            transition: background 0.2s; margin-bottom: 8px;
        }
        .share-copy-btn:hover { background: var(--bright-gold); }
        .share-copy-btn.copied { background: #4caf50; color: white; }
        .share-close {
            position: absolute; top: 12px; right: 14px;
            background: none; border: none; color: #888;
            font-size: 1.4em; cursor: pointer; line-height: 1;
        }
        .share-close:hover { color: var(--gold); }
        .share-platforms { display: flex; gap: 8px; margin-top: 4px; }
        .share-platform-btn {
            flex: 1; padding: 9px 5px; border-radius: 8px; border: 1px solid #444;
            background: #111; color: #ccc; font-family: sans-serif; font-size: 0.75em;
            cursor: pointer; transition: border-color 0.2s, color 0.2s; text-align: center;
        }
        .share-platform-btn:hover { border-color: var(--gold); color: #fff; }

        /* HASHTAG FOOTER */
        .hashtag-footer { width: 100%; max-width: 600px; text-align: center; padding: 10px 0 40px 0; }
        .hashtag-footer a { font-family: 'Cinzel', serif; font-size: 0.8em; letter-spacing: 3px; color: var(--gold); text-decoration: none; opacity: 0.7; transition: opacity 0.2s; }
        .hashtag-footer a:hover { opacity: 1; }

        /* MAGIC BUTTON */
        .magic-btn-container { width: 100%; max-width: 600px; margin-top: 12px; }
        .magic-btn {
            width: 100%; padding: 13px;
            background: linear-gradient(135deg, #1a1200, #2e1f00);
            border: 1.5px solid var(--gold);
            color: var(--gold);
            font-family: 'Cinzel', serif;
            font-size: clamp(0.8em, 2.5vw, 1em);
            letter-spacing: 2px;
            border-radius: 8px; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            transition: background 0.3s, box-shadow 0.3s;
            position: relative; overflow: hidden;
        }
        .magic-btn:hover:not(:disabled) { background: linear-gradient(135deg, #2e1f00, #4a3200); box-shadow: 0 0 18px rgba(197,160,89,0.35); }
        .magic-btn:disabled { opacity: 0.6; cursor: default; }
        .magic-btn .sparkle { font-size: 1.2em; transition: transform 0.3s; }
        .magic-btn:hover:not(:disabled) .sparkle { transform: rotate(20deg) scale(1.2); }
        @keyframes shimmer { 0% { left: -100%; } 100% { left: 200%; } }
        .magic-btn.animating::after {
            content: ''; position: absolute; top: 0; left: -100%;
            width: 60%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,215,0,0.15), transparent);
            animation: shimmer 1.2s infinite;
        }

        /* ZOOM sul papiro */
        .comparison-container.zoomed { cursor: zoom-out; }
        .comparison-container.zoomed .papiro-img { transform-origin: var(--zoom-x, 50%) var(--zoom-y, 50%); transform: scale(2.5); transition: transform 0.3s ease; }
        .comparison-container .papiro-img { transition: transform 0.3s ease; }
        .zoom-hint { position: absolute; bottom: 34px; right: 10px; background: rgba(0,0,0,0.6); color: var(--bright-gold); font-family: 'Cinzel', serif; font-size: 0.6em; letter-spacing: 1px; padding: 4px 8px; border-radius: 10px; pointer-events: none; z-index: 11; opacity: 0.8; }

        /* THUMBNAIL STRIP sotto il papiro */
        .thumb-strip { width: 100%; max-width: 600px; display: flex; gap: 10px; margin-top: 10px; }
        .thumb-item { flex: 1; cursor: pointer; border-radius: 6px; overflow: hidden; border: 1px solid #333; transition: border-color 0.2s, transform 0.2s; position: relative; background: #111; }
        .thumb-item:hover { border-color: var(--gold); transform: translateY(-2px); }
        .thumb-item img { width: 100%; height: 80px; object-fit: cover; display: block; opacity: 0.85; transition: opacity 0.2s; }
        .thumb-item:hover img { opacity: 1; }
        .thumb-label { font-family: 'Cinzel', serif; font-size: 0.55em; letter-spacing: 1px; color: var(--gold); text-align: center; padding: 5px 4px; text-transform: uppercase; line-height: 1.3; background: #1a1500; }

        /* LIGHTBOX */
        .lightbox-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 2000; align-items: center; justify-content: center; padding: 16px; flex-direction: column; gap: 12px; }
        .lightbox-overlay.active { display: flex; }
        .lightbox-img { max-width: 100%; max-height: 80vh; object-fit: contain; border: 1px solid var(--gold); border-radius: 6px; }
        .lightbox-caption { font-family: 'Cinzel', serif; font-size: 0.7em; letter-spacing: 2px; color: var(--gold); text-align: center; opacity: 0.8; }
        .lightbox-close { position: absolute; top: 16px; right: 20px; background: none; border: none; color: #aaa; font-size: 2em; cursor: pointer; line-height: 1; }
        .lightbox-close:hover { color: var(--bright-gold); }

        /* RETRO TEXT - dentro .content */
        .retro-block { margin-top: 22px; padding-top: 18px; border-top: 1px solid #2a2a2a; }
        .retro-block-title { font-family: 'Cinzel', serif; font-size: 0.8em; letter-spacing: 2px; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; opacity: 0.9; }
        .retro-block p { font-size: 0.95em; color: #aaa; margin: 0; }

        /* SCROLL FADE-IN */
        .fade-in-section { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
        .fade-in-section.visible { opacity: 1; transform: translateY(0); }

        /* MAGIC COMPLETE PULSE */
        @keyframes magicComplete { 0%,100% { box-shadow: 0 0 0 rgba(255,215,0,0); } 50% { box-shadow: 0 0 30px rgba(255,215,0,0.4); } }
        .magic-complete { animation: magicComplete 0.6s ease 2; }
        @media (max-width: 420px) {
            body { padding: 10px; }
            .top-bar { margin-bottom: 10px; }
            button.lang-btn { padding: 4px 6px; }
            .share-btn, .insta-btn { width: 30px; height: 30px; }
            #faq-container { grid-template-columns: 1fr; }
            .faq-btn { font-size: 0.9em; }
            .external-links { gap: 5px; }
            .link-btn { font-size: 0.58em; padding: 9px 3px; }
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <div class="lang-switch">
            <button id="btn-it" class="lang-btn active" onclick="changeLang('it')">
                <svg width="25px" height="25px" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
                    <path style="fill:#73AF00;" d="M38.345,88.273C17.167,88.273,0,105.44,0,126.618v258.759c0,21.177,17.167,38.345,38.345,38.345 h132.322V88.273H38.345z"/>
                    <rect x="170.67" y="88.277" style="fill:#F5F5F5;" width="170.67" height="335.45"/>
                    <path style="fill:#FF4B55;" d="M473.655,88.273H341.333v335.448h132.322c21.177,0,38.345-17.167,38.345-38.345V126.618 C512,105.44,494.833,88.273,473.655,88.273z"/>
                </svg>
            </button>
            <button id="btn-en" class="lang-btn" onclick="changeLang('en')">
                <svg width="25px" height="25px" viewBox="0 -4 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g clip-path="url(#clip0_503_2952)">
                    <rect width="28" height="20" rx="2" fill="white"/>
                    <mask id="mask0_503_2952" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="28" height="20">
                    <rect width="28" height="20" rx="2" fill="white"/>
                    </mask>
                    <g mask="url(#mask0_503_2952)">
                    <rect width="28" height="20" fill="#0A17A7"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M-1.28244 -1.91644L10.6667 6.14335V-1.33333H17.3334V6.14335L29.2825 -1.91644L30.7737 0.294324L21.3263 6.66667H28V13.3333H21.3263L30.7737 19.7057L29.2825 21.9165L17.3334 13.8567V21.3333H10.6667V13.8567L-1.28244 21.9165L-2.77362 19.7057L6.67377 13.3333H2.95639e-05V6.66667H6.67377L-2.77362 0.294324L-1.28244 -1.91644Z" fill="white"/>
                    <path d="M18.668 6.33219L31.3333 -2" stroke="#DB1F35" stroke-width="0.666667" stroke-linecap="round"/>
                    <path d="M20.0128 13.6975L31.3666 21.3503" stroke="#DB1F35" stroke-width="0.666667" stroke-linecap="round"/>
                    <path d="M8.00555 6.31046L-3.83746 -1.67099" stroke="#DB1F35" stroke-width="0.666667" stroke-linecap="round"/>
                    <path d="M9.29006 13.6049L-3.83746 22.3105" stroke="#DB1F35" stroke-width="0.666667" stroke-linecap="round"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M0 12H12V20H16V12H28V8H16V0H12V8H0V12Z" fill="#E6273E"/>
                    </g>
                    </g>
                    <defs>
                    <clipPath id="clip0_503_2952">
                    <rect width="28" height="20" rx="2" fill="white"/>
                    </clipPath>
                    </defs>
                </svg>
            </button>
        </div>
        <div class="social-actions">
            <a href="#" target="_blank" class="insta-btn" onclick="shareToInstagram(event)">
                <svg width="22" height="22" viewBox="0 0 3364.7 3364.7" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <radialGradient id="grad0" cx="217.76" cy="3290.99" r="4271.92" gradientUnits="userSpaceOnUse"><stop offset=".09" stop-color="#fa8f21"/><stop offset=".78" stop-color="#d82d7e"/></radialGradient>
                        <radialGradient id="grad1" cx="2330.61" cy="3182.95" r="3759.33" gradientUnits="userSpaceOnUse"><stop offset=".64" stop-color="#8c3aaa" stop-opacity="0"/><stop offset="1" stop-color="#8c3aaa"/></radialGradient>
                    </defs>
